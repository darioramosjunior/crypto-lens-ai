#!/bin/bash
# Pre-commit hook for running tests
# Install this hook by running: python setup_pre_commit.py

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Check if pytest is installed
if ! command -v pytest &> /dev/null; then
    echo -e "${RED}pytest is not installed. Please run: pip install pytest${NC}"
    exit 1
fi

# Run tests
echo -e "${YELLOW}Running unit tests...${NC}"
pytest tests/ -v --tb=short

# Check test result
if [ $? -ne 0 ]; then
    echo -e "${RED}Tests failed! Commit aborted.${NC}"
    exit 1
fi

# Run linting checks (optional - don't fail on this)
echo -e "${YELLOW}Running code quality checks...${NC}"
flake8 --select=E9,F63,F7,F82 . --show-source 2>/dev/null || true

echo -e "${GREEN}Pre-commit checks passed!${NC}"
exit 0
